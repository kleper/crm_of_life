# -----------------------------------------------------------------------------
# Base de Datos PostgreSQL
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@db:5432/crm_vida?schema=public

# -----------------------------------------------------------------------------
# Configuración del Súper Administrador Inicial (Seed)
# Este usuario se creará automáticamente la primera vez que inicies la app.
# -----------------------------------------------------------------------------
INITIAL_SUPERADMIN_EMAIL=admin@tudominio.com
INITIAL_SUPERADMIN_PASSWORD=CambiarEnProduccion123!

# -----------------------------------------------------------------------------
# Seguridad / NextAuth (Auth.js)
# Genera un nuevo secreto ejecutando: openssl rand -base64 32
# -----------------------------------------------------------------------------
AUTH_SECRET=genera_un_secreto_seguro_aqui_para_jwt
AUTH_TRUST_HOST=true
# En producción, asegúrate de definir la URL pública (ej. https://crm.tudominio.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Notificaciones Web Push (VAPID)
# Genera tus propias llaves VAPID usando `npx web-push generate-vapid-keys`
# -----------------------------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=tu_vapid_public_key
VAPID_PRIVATE_KEY=tu_vapid_private_key

# -----------------------------------------------------------------------------
# Tareas Recurrentes (Cron Jobs)
# Secreto para proteger los endpoints de cron
# -----------------------------------------------------------------------------
CRON_SECRET=secreto_aleatorio_para_proteger_el_cron
